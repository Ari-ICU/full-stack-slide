# app/Http/Controllers/ProductController.php
# (add to existing file — DO NOT recreate)

use App\Http\Requests\UpdateProductRequest;  // ← from m08c

public function edit(Product $product) {
    // Route Model Binding: Laravel auto-fetches Product by ID from URL
    $categories = Category::all();
    return view('products.edit', compact('product', 'categories'));
}

public function update(UpdateProductRequest $request, Product $product) {
    // Validation handled by UpdateProductRequest (m08c)
    $data = $request->validated();

    if ($request->hasFile('image')) {
        // Delete the OLD image to save disk space
        if ($product->image) {
            Storage::disk('public')->delete($product->image);
        }
        $data['image'] = $request->file('image')
            ->store('products', 'public');
    }

    $product->update($data);

    return redirect()
        ->route('products.index')
        ->with('success', 'Product updated!');
}`,
