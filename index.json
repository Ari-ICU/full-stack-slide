      { en: "Sanctum vs JWT", kh: "Comparison", answerEn: "Sanctum: DB lookup (easy revoke). JWT: code decode (faster, hard revoke).", answerKh: "Sanctum ឆែក DB (ងាយ revoke). JWT decode ដោយ code (លឿន, ពិបាក revoke)។" },
      { en: "When to use which?", kh: "When?", answerEn: "Sanctum for most apps. JWT for microservices at scale.", answerKh: "Sanctum App ទូទៅ, JWT microservices ធំ scale។" }
