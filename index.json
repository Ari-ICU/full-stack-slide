# MODULE 09B — Create ProductController (FIRST TIME!)
# This is the ONE time we create this controller.
# Subsequent modules add methods to the same file.
# ══════════════════════════════════════════════

# Create the resource controller
php artisan make:controller ProductController --resource
# → app/Http/Controllers/ProductController.php
# → Contains: index, create, store, show, edit, update, destroy

# routes/web.php — add resource route (replaces manual routes)
Route::resource('products', ProductController::class);
# This creates all 7 routes automatically!

# Verify routes:
php artisan route:list --path=products
# GET    /products           → index
# GET    /products/create    → create
# POST   /products           → store
# GET    /products/{id}      → show
# GET    /products/{id}/edit → edit
# PUT    /products/{id}      → update
# DELETE /products/{id}      → destroy

# app/Http/Controllers/ProductController.php
public function index(Request $request) {
    $products = Product::with('category')
        ->when($request->search, function ($query, $search) {
            $query->where('name', 'like', "%{$search}%")
                  ->orWhere('description', 'like', "%{$search}%");
        })
        ->latest()
        ->paginate(12)
        ->withQueryString();

    return view('products.index', compact('products'));
}

# resources/views/products/index.blade.php
