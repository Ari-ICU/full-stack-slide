      code: `# ══════════════════════════════════════════════
# MODULE 11B — ProductPolicy for existing Product model (m06)
# ══════════════════════════════════════════════

# Create policy (--model links it to Product automatically)
php artisan make:policy ProductPolicy --model=Product
# → app/Policies/ProductPolicy.php

# app/Policies/ProductPolicy.php
class ProductPolicy {
    public function viewAny(User $user): bool {
        return true; // All authenticated users can list
    }

    public function view(User $user, Product $product): bool {
        return true; // All can view
    }

    public function create(User $user): bool {
        return in_array($user->role, ['admin', 'editor']);
    }

    public function update(User $user, Product $product): bool {
        // Owner OR admin can update
        return $user->id === $product->user_id
            || $user->role === 'admin';
    }

    public function delete(User $user, Product $product): bool {
        // Only owner can delete (or admin)
        return $user->id === $product->user_id
            || $user->role === 'admin';
    }
}

# app/Http/Controllers/ProductController.php (from m09b)
# ADD authorize calls to methods:
public function update(UpdateProductRequest $request, Product $product) {
    $this->authorize('update', $product); // Uses ProductPolicy::update()
    // ... rest of update logic from m09d
}

public function destroy(Product $product) {
    $this->authorize('delete', $product); // Uses ProductPolicy::delete()
    // ... rest of destroy logic from m09e
}`,
