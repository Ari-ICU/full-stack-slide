      code: `# ══════════════════════════════════════════════
# MODULE 19B — Cache product queries in ProductController (from m09b)
# ══════════════════════════════════════════════

# app/Http/Controllers/ProductController.php — UPDATE index()
use Illuminate\Support\Facades\Cache;

public function index(Request $request) {
    // Build cache key (include search so different searches cache separately)
    $cacheKey = 'products.index.' . md5($request->getQueryString() ?? '');

    $products = Cache::remember($cacheKey, 3600, function () use ($request) {
        return Product::with('category')
            ->when($request->search, function ($query, $search) {
                $query->where('name', 'like', "%{$search}%");
            })
            ->latest()
            ->paginate(12)
            ->withQueryString();
    });
    // First call: runs DB query, stores result for 3600 seconds
    // Repeat calls within 1 hour: returns cached result (no DB!)

    return view('products.index', compact('products'));
}

# IMPORTANT: Clear cache when products change!

public function store(StoreProductRequest $request) {
    // ... existing store logic from m09c ...
    Cache::flush(); // clear all caches after creating product
    return redirect()->route('products.index')->with('success', 'Created!');
}

public function update(UpdateProductRequest $request, Product $product) {
    // ... existing update logic from m09d ...
    Cache::flush(); // clear cache after update
    return redirect()->route('products.index')->with('success', 'Updated!');
}

public function destroy(Product $product) {
    // ... existing destroy logic from m09e ...
    Cache::flush(); // clear cache after delete
    return redirect()->route('products.index')->with('success', 'Deleted!');
}`,
      output: `First request:  DB query runs → 45ms → stored in Redis ✓
Second request: Redis cache hit → 8ms (no DB!) ✓
After update:   cache cleared → next request hits DB fresh ✓`,
    },
    tip: "Only cache data that is read often but changed rarely. Product listing = perfect candidate.",
    project: null,
  },

