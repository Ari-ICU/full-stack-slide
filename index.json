public function destroy(Product $product) {
    // Delete image file from storage first
    if ($product->image) {
        Storage::disk('public')->delete($product->image);
    }
    $product->delete();

    return redirect()
        ->route('products.index')
        ->with('success', 'Product deleted!');
}

