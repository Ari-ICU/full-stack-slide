# MODULE 16 — Add Queue support to my-shop
# ══════════════════════════════════════════════

# .env — change queue driver
QUEUE_CONNECTION=database
# (was 'sync' by default — sync defeats the purpose of queues!)

# Create queue tables migration
php artisan queue:table
php artisan queue:failed-table

# Run migrations (adds to existing DB)
php artisan migrate
# → Creates: jobs table
# → Creates: failed_jobs table

# Verify:
php artisan migrate:status
# → jobs ✓
# → failed_jobs ✓

# With 'sync' driver: job runs IMMEDIATELY in same request (blocks!)
# With 'database' driver: job is stored in jobs table, worker processes it

# Why queues?
# Without queue: POST /register → send email (2 seconds) → redirect
# With queue:    POST /register → push to jobs table → redirect (instant!)
#                               (worker processes email in background)`,
