      code: `# ══════════════════════════════════════════════
# MODULE 07 — Configure models from m06, then CRUD
# Models (Category, Product, Tag) were created in m06
# NO new make:model here
# ══════════════════════════════════════════════

# app/Models/Category.php — ADD relationships
class Category extends Model {
    protected $fillable = ['name'];

    public function products() {
        return $this->hasMany(Product::class);
    }
}

# app/Models/Product.php — ADD fillable + casts + relationship
class Product extends Model {
    protected $fillable = [
        'category_id', 'name', 'description',
        'price', 'image', 'is_active'
    ];
    protected $casts = [
        'price'     => 'decimal:2',
        'is_active' => 'boolean',
    ];
    public function category() {
        return $this->belongsTo(Category::class);
    }
}

# ── Tinker CRUD Demo ─────────────────────────
php artisan tinker

# CREATE
>>> Category::create(['name' => 'Electronics'])
>>> Product::create(['category_id'=>1, 'name'=>'iPhone 15', 'price'=>999])

# READ
>>> Product::all()
>>> Product::find(1)

# EAGER LOADING (fix N+1)
>>> DB::enableQueryLog()
>>> $products = Product::all();
>>> foreach($products as $p) { $p->category->name; } // BAD: N+1
>>> DB::getQueryLog() // shows many queries!

>>> DB::flushQueryLog()
>>> $products = Product::with('category')->get(); // GOOD: 2 queries
>>> DB::getQueryLog() // shows only 2 queries!

# UPDATE
>>> Product::find(1)->update(['price' => 899])

# DELETE
>>> Product::find(1)->delete()`,
      output: `>>> Product::with('category')->first()->category->name
=> "Electronics"

DB::getQueryLog() — WITHOUT with(): 51 queries
DB::getQueryLog() — WITH with():    2 queries  ✓`,
