# MODULE 06 — Create ALL tables for my-shop (ONCE ONLY)
# After this module: NO NEW make:model or make:migration for core tables
# ══════════════════════════════════════════════

# Generate models WITH their migrations (-m flag)
php artisan make:model Category -m
php artisan make:model Product -m
php artisan make:model Tag -m
php artisan make:migration create_product_tag_table

# ── FILL IN MIGRATION FILES ──────────────────

# database/migrations/xxxx_create_categories_table.php
public function up(): void {
    Schema::create('categories', function (Blueprint $table) {
        $table->id();
        $table->string('name');
        $table->timestamps();
    });
}

# database/migrations/xxxx_create_products_table.php
public function up(): void {
    Schema::create('products', function (Blueprint $table) {
        $table->id();
        $table->foreignId('category_id')->constrained()->cascadeOnDelete();
        $table->string('name');
        $table->text('description')->nullable();
        $table->decimal('price', 10, 2);     // NEVER use float for money!
        $table->string('image')->nullable();
        $table->boolean('is_active')->default(true);
        $table->timestamps();
    });
}

# database/migrations/xxxx_create_tags_table.php
public function up(): void {
    Schema::create('tags', function (Blueprint $table) {
        $table->id();
        $table->string('name');
        $table->timestamps();
    });
}

# database/migrations/xxxx_create_product_tag_table.php
public function up(): void {
    Schema::create('product_tag', function (Blueprint $table) {
        $table->id();
        $table->foreignId('product_id')->constrained()->cascadeOnDelete();
        $table->foreignId('tag_id')->constrained()->cascadeOnDelete();
        $table->timestamps();
    });
}

# ── RUN ALL MIGRATIONS ───────────────────────
php artisan migrate
php artisan migrate:status`,
