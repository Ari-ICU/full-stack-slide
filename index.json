# MODULE 11 — Add Gates to my-shop
# AppServiceProvider already exists by default
# ══════════════════════════════════════════════

# app/Providers/AppServiceProvider.php (already exists)
# ADD to boot() method:
use Illuminate\Support\Facades\Gate;

public function boot(): void {
    // Global gate: only users with role='admin' can access admin features
    Gate::define('access-admin', function ($user) {
        return $user->role === 'admin';
    });

    // Gate for managing products (admin or editor role)
    Gate::define('manage-products', function ($user) {
        return in_array($user->role, ['admin', 'editor']);
    });
}

# app/Http/Controllers/ProductController.php (from m09b)
# ADD to destroy() — extra layer of protection:
public function destroy(Product $product) {
    Gate::authorize('manage-products');  // Throws 403 if denied

    if ($product->image) {
        Storage::disk('public')->delete($product->image);
    }
    $product->delete();
    return redirect()->route('products.index')->with('success', 'Deleted!');
}

# resources/views/products/index.blade.php (from m09b/e)
# UPDATE delete button with @can:
@can('manage-products')
    <form action="{{ route('products.destroy', $product) }}" method="POST">
        @csrf @method('DELETE')
        <button onclick="return confirm('Delete?')">Delete</button>
    </form>
@endcan`,
